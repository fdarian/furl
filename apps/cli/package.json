{
  "name": "furl-cli",
  "version": "0.2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fdarian/furl.git",
    "directory": "apps/cli"
  },
  "bin": {
    "furl": "./dist/cli.js"
  },
  "exports": {
    "./plugins": "./src/plugins.ts"
  },
  "files": [
    "dist",
    "src/plugins.ts",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bun build src/main.ts --target=bun --outfile dist/cli.js",
    "build:binaries": "bun run scripts/build-binaries.ts",
    "prepack": "bun run build",
    "check:tsc": "tsc --noEmit",
    "check:lint": "biome check ."
  },
  "devDependencies": {
    "@effect/platform-bun": "4.0.0-beta.83",
    "@furl/core": "workspace:*",
    "@repo/config": "workspace:*",
    "effect": "4.0.0-beta.83"
  }
}
